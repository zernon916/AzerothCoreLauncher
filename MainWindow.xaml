<Window x:Class="AzerothCoreLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AzerothCoreLauncher"
        Title="AzerothCore Launcher" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:GMLevelToBoolConverter x:Key="GMLevelToBoolConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Control Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#FF2D2D30">
            <!-- Auth Server Section -->
            <StackPanel Orientation="Horizontal" Margin="5">
                <Ellipse x:Name="AuthStatusLight" Width="15" Height="15" Fill="Red" Margin="5" VerticalAlignment="Center"/>
                <TextBlock Text="Auth:" Foreground="White" VerticalAlignment="Center" Margin="5"/>
                <Button x:Name="BtnStartAuth" Content="Start" Width="70" Height="30" Margin="5" Click="BtnStartAuth_Click"/>
                <Button x:Name="BtnStopAuth" Content="Stop" Width="70" Height="30" Margin="5" Click="BtnStopAuth_Click" IsEnabled="False"/>
                <TextBlock x:Name="AuthMemory" Text="0 MB" Foreground="LightGreen" VerticalAlignment="Center" Margin="10,0,5,0"/>
            </StackPanel>
            
            <Separator Width="30" Background="#FF555555"/>
            
            <!-- World Server Section -->
            <StackPanel Orientation="Horizontal" Margin="5">
                <Ellipse x:Name="WorldStatusLight" Width="15" Height="15" Fill="Red" Margin="5" VerticalAlignment="Center"/>
                <TextBlock Text="World:" Foreground="White" VerticalAlignment="Center" Margin="5"/>
                <Button x:Name="BtnStartWorld" Content="Start" Width="70" Height="30" Margin="5" Click="BtnStartWorld_Click"/>
                <Button x:Name="BtnStopWorld" Content="Stop" Width="70" Height="30" Margin="5" Click="BtnStopWorld_Click" IsEnabled="False"/>
                <TextBlock x:Name="WorldMemory" Text="0 MB" Foreground="LightGreen" VerticalAlignment="Center" Margin="10,0,5,0"/>
            </StackPanel>
            
            <Separator Width="30" Background="#FF555555"/>
            
            <!-- Scheduled Restart -->
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Restart at:" Foreground="White" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtRestartTime" Width="50" Height="30" Margin="5" Text="00:00"/>
                <Button x:Name="BtnScheduleRestart" Content="Schedule" Width="80" Height="30" Margin="5" Click="BtnScheduleRestart_Click"/>
                <Button x:Name="BtnCancelRestart" Content="Cancel" Width="80" Height="30" Margin="5" Click="BtnCancelRestart_Click" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Tab Control -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10">
            <!-- Server Status Tab -->
            <TabItem Header="Server Status">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Auth Server Status -->
                    <Border Grid.Row="0" BorderBrush="#FF555555" BorderThickness="1" Margin="10" Padding="20" Background="#FF2D2D30">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AuthStatusLightLarge" Width="30" Height="30" Fill="Red" Margin="10"/>
                            <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock Text="Authentication Server" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="AuthStatusText" Text="Status: Stopped" FontSize="14" Foreground="LightGray" Margin="0,5,0,0"/>
                                <TextBlock x:Name="AuthMemoryLarge" Text="Memory: 0 MB" FontSize="14" Foreground="LightGreen" Margin="0,5,0,0"/>
                                <TextBlock x:Name="AuthUptime" Text="Uptime: 00:00:00" FontSize="14" Foreground="LightBlue" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- World Server Status -->
                    <Border Grid.Row="1" BorderBrush="#FF555555" BorderThickness="1" Margin="10" Padding="20" Background="#FF2D2D30">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="WorldStatusLightLarge" Width="30" Height="30" Fill="Red" Margin="10"/>
                            <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock Text="World Server" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="WorldStatusText" Text="Status: Stopped" FontSize="14" Foreground="LightGray" Margin="0,5,0,0"/>
                                <TextBlock x:Name="WorldMemoryLarge" Text="Memory: 0 MB" FontSize="14" Foreground="LightGreen" Margin="0,5,0,0"/>
                                <TextBlock x:Name="WorldUptime" Text="Uptime: 00:00:00" FontSize="14" Foreground="LightBlue" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Scheduled Restart Info -->
                    <Border x:Name="RestartInfoBorder" Grid.Row="2" BorderBrush="#FF555555" BorderThickness="1" Margin="10" Padding="20" Background="#FF2D2D30" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="RestartCountdownText" Text="Scheduled restart in: 00:00:00" FontSize="16" FontWeight="Bold" Foreground="Yellow" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="RestartTargetText" Text="Target: World Server" FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Console Tab -->
            <TabItem Header="Console">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Auth Console -->
                    <RichTextBox x:Name="AuthConsole" Grid.Row="0" Grid.Column="0" IsReadOnly="True" 
                                 Background="#FF1E1E1E" Foreground="#FF00FFFF" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" Margin="5"/>
                    
                    <!-- Resizable Splitter -->
                    <GridSplitter Grid.Row="0" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF555555"/>
                    
                    <!-- World Console -->
                    <RichTextBox x:Name="WorldConsole" Grid.Row="0" Grid.Column="2" IsReadOnly="True" 
                                 Background="#FF1E1E1E" Foreground="#FF00FF00" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" Margin="5"/>
                    
                    <!-- Command Input (spans both columns) -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Command:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="White"/>
                        <TextBox x:Name="CommandInput" Width="600" Height="30" FontFamily="Consolas" FontSize="12"
                                 KeyDown="CommandInput_KeyDown"/>
                        <TextBlock Text="Target:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="White"/>
                        <ComboBox x:Name="CommandTarget" Width="100" Height="30" Margin="0,0,5,0">
                            <ComboBoxItem Content="World" IsSelected="True"/>
                            <ComboBoxItem Content="Auth"/>
                        </ComboBox>
                        <Button Content="Send" Width="80" Height="30" Margin="5" Click="BtnSendCommand_Click"/>
                        <Button Content="Clear Console" Width="120" Height="30" Margin="5" Click="BtnClearConsole_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Events Tab -->
            <TabItem Header="Events">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Event Controls -->
                    <Border Grid.Row="0" BorderBrush="#FF555555" BorderThickness="1" Background="#FF222222" Padding="15" Margin="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Row 1: Event Name and Type -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Event Name" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtEventName" Grid.Column="1" Height="30" Margin="0,0,15,0"/>
                                    
                                    <TextBlock Grid.Column="2" Text="Type" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="CmbEventType" Grid.Column="3" Height="30">
                                        <ComboBoxItem Content="Command" IsSelected="True"/>
                                        <ComboBoxItem Content="Restart"/>
                                        <ComboBoxItem Content="Announcement"/>
                                    </ComboBox>
                                </Grid>
                                
                                <!-- Row 2: Target and Time -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Target" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="CmbEventTarget" Grid.Column="1" Height="30">
                                        <ComboBoxItem Content="World" IsSelected="True"/>
                                        <ComboBoxItem Content="Auth"/>
                                    </ComboBox>
                                    
                                    <TextBlock Grid.Column="2" Text="Time (HH:mm)" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtEventTime" Grid.Column="3" Height="30" Text="00:00"/>
                                </Grid>
                                
                                <!-- Row 3: Command and Recurring -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Command" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtEventCommand" Grid.Column="1" Height="30" Margin="0,0,15,0"/>
                                    
                                    <CheckBox x:Name="ChkEventEnabled" Grid.Column="2" Content="Enabled" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0" IsChecked="True"/>
                                    <CheckBox x:Name="ChkEventRecurring" Grid.Column="3" Content="Recurring" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                </Grid>
                                
                                <!-- Row 4: Recurrence Pattern -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Recurrence" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="CmbRecurrencePattern" Grid.Column="1" Height="30" SelectionChanged="CmbRecurrencePattern_SelectionChanged">
                                        <ComboBoxItem Content="Daily" IsSelected="True"/>
                                        <ComboBoxItem Content="Weekly"/>
                                        <ComboBoxItem Content="Monthly"/>
                                        <ComboBoxItem Content="Custom"/>
                                    </ComboBox>
                                    
                                    <TextBlock Grid.Column="2" Text="Interval (days)" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0" Visibility="Collapsed" x:Name="LblInterval"/>
                                    <TextBox x:Name="TxtRecurrenceInterval" Grid.Column="3" Height="30" Text="1" Visibility="Collapsed"/>
                                </Grid>
                                
                                <!-- Row 5: Weekly Days -->
                                <Grid Margin="0,0,0,10" Visibility="Collapsed" x:Name="WeeklyDaysPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Days" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox x:Name="ChkMon" Content="Mon" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkTue" Content="Tue" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkWed" Content="Wed" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkThu" Content="Thu" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkFri" Content="Fri" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkSat" Content="Sat" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkSun" Content="Sun" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Row 6: Monthly Day -->
                                <Grid Margin="0,0,0,10" Visibility="Collapsed" x:Name="MonthlyDayPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Day of Month" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtDayOfMonth" Grid.Column="1" Height="30" Text="1"/>
                                </Grid>
                                
                                <!-- Row 7: Event Chaining -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Chain Delay (s)" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtChainDelay" Grid.Column="1" Height="30" Text="0"/>
                                    
                                    <TextBlock Grid.Column="2" Text="Chain Events" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="3" Text="Select events to chain after this one" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Row 8: Conditional Execution -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox x:Name="ChkHasConditions" Grid.Column="0" Content="Conditions" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0" Checked="ChkHasConditions_Checked" Unchecked="ChkHasConditions_Unchecked"/>
                                    <TextBlock Grid.Column="1" Text="Execute only if conditions are met" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Row 9: Player Count Conditions -->
                                <Grid Margin="0,0,0,10" Visibility="Collapsed" x:Name="ConditionsPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Min Players" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtMinPlayers" Grid.Column="1" Height="30" Text=""/>
                                    
                                    <TextBlock Grid.Column="2" Text="Max Players" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtMaxPlayers" Grid.Column="3" Height="30" Text=""/>
                                </Grid>
                                
                                <!-- Row 10: Time Window -->
                                <Grid Margin="0,0,0,10" Visibility="Collapsed" x:Name="TimeWindowPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Start Time" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtStartTimeWindow" Grid.Column="1" Height="30" Text=""/>
                                    
                                    <TextBlock Grid.Column="2" Text="End Time" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtEndTimeWindow" Grid.Column="3" Height="30" Text=""/>
                                </Grid>
                                
                                <!-- Row 11: Buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
                                    <Button x:Name="BtnAddEvent" Content="Add" Width="70" Height="30" Margin="0,0,5,0" Click="BtnAddEvent_Click"/>
                                    <Button x:Name="BtnDeleteEvent" Content="Delete" Width="70" Height="30" Margin="0,0,5,0" Click="BtnDeleteEvent_Click"/>
                                    <Button x:Name="BtnSaveEvents" Content="Save" Width="70" Height="30" Click="BtnSaveEvents_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Event List -->
                    <DataGrid x:Name="EventList" Grid.Row="2" AutoGenerateColumns="False" Margin="10"
                              IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="60"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding ScheduledTime, StringFormat=hh\\:mm}" Width="60"/>
                            <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="200"/>
                            <DataGridCheckBoxColumn Header="Recurring" Binding="{Binding IsRecurring}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Account Management Tab -->
            <TabItem Header="Account Management" Selector.Selected="AccountManagementTab_Selected">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Create Account -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Create Account" Width="120" Height="30" Margin="5" Click="BtnCreateAccount_Click"/>
                        </StackPanel>
                        
                        <Separator Margin="0,10,0,10"/>
                        
                        <!-- Account Search -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="AccountSearch" Width="200" Height="30" Margin="5"/>
                            <Button Content="Search Account" Width="120" Height="30" Margin="5" Click="BtnSearchAccount_Click"/>
                            <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshAccount_Click"/>
                        </StackPanel>
                        
                        <!-- Account List -->
                        <DataGrid x:Name="DgAccounts" Height="200" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                                <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150"/>
                                <DataGridTextColumn Header="Last IP" Binding="{Binding LastIP}" Width="120"/>
                                <DataGridTextColumn Header="Online" Binding="{Binding Online}" Width="60"/>
                                <DataGridTextColumn Header="Locked" Binding="{Binding Locked}" Width="60"/>
                                <DataGridTemplateColumn Header="GM" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding GMLevel, Converter={StaticResource GMLevelToBoolConverter}}" Click="BtnToggleGM_Click" Tag="{Binding Username}" Width="40" Height="20"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Actions" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Edit" Click="BtnEditAccount_Click" Tag="{Binding Username}" Width="40" Margin="0,0,5,0"/>
                                                <Button Content="Delete" Click="BtnDeleteAccount_Click" Tag="{Binding Username}" Width="50" Background="#FFB22222" Foreground="White"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <TextBlock Text="Account Management" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>
                        
                        <!-- Account Ban Management -->
                        <TextBlock Text="Account Ban Management" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid x:Name="DgAccountBans" Height="200" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Account" Binding="{Binding AccountId}" Width="120"/>
                                <DataGridTextColumn Header="Ban Date" Binding="{Binding BanDateFormatted}" Width="150"/>
                                <DataGridTextColumn Header="Unban Date" Binding="{Binding UnbanDateFormatted}" Width="150"/>
                                <DataGridTextColumn Header="Banned By" Binding="{Binding BannedBy}" Width="100"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding BanReason}" Width="*"/>
                                <DataGridTextColumn Header="Active" Binding="{Binding ActiveFormatted}" Width="60"/>
                                <DataGridTemplateColumn Header="Actions" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Edit" Click="BtnEditBannedAccount_Click" Tag="{Binding AccountId}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Refresh Account Bans" Width="150" Height="30" Margin="0,5" HorizontalAlignment="Left" Click="BtnRefreshAccountBans_Click"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- IP Ban Management -->
                        <TextBlock Text="IP Ban Management" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBanIP" Grid.Column="0" Height="30" Margin="0,0,5,0" Text=""/>
                            <Button x:Name="BtnBanIP" Grid.Column="1" Content="Ban/Unban IP" Width="100" Height="30" Click="BtnBanIP_Click"/>
                        </Grid>
                        <DataGrid x:Name="DgIPBans" Height="200" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IP}" Width="200"/>
                                <DataGridTextColumn Header="Ban Date" Binding="{Binding BanDateFormatted}" Width="150"/>
                                <DataGridTextColumn Header="Unban Date" Binding="{Binding UnbanDateFormatted}" Width="150"/>
                                <DataGridTextColumn Header="Banned By" Binding="{Binding BannedBy}" Width="100"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding BanReason}" Width="*"/>
                                <DataGridTemplateColumn Header="Actions" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Unban" Click="BtnUnbanIP_Click" Tag="{Binding IP}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Refresh IP Bans" Width="120" Height="30" Margin="0,5" HorizontalAlignment="Left" Click="BtnRefreshIPBans_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Players Tab -->
            <TabItem Header="Players">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Player Search -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                        <TextBox x:Name="PlayerSearch" Width="200" Height="30" Margin="5"/>
                        <Button Content="Search Online" Width="100" Height="30" Margin="5" Click="BtnSearchPlayer_Click"/>
                        <Button Content="Search Offline" Width="100" Height="30" Margin="5" Click="BtnSearchOfflinePlayer_Click"/>
                        <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshPlayers_Click"/>
                        <Separator Width="20"/>
                        <ComboBox x:Name="CmbGMAction" Width="150" Height="30" Margin="5">
                            <ComboBoxItem Content="Kick"/>
                            <ComboBoxItem Content="Ban"/>
                            <ComboBoxItem Content="Mute"/>
                            <ComboBoxItem Content="GM On"/>
                            <ComboBoxItem Content="GM Off"/>
                        </ComboBox>
                        <Button Content="Execute" Width="80" Height="30" Margin="5" Click="BtnExecuteGM_Click"/>
                    </StackPanel>
                    
                    <!-- Player List -->
                    <DataGrid x:Name="PlayerList" Grid.Row="1" AutoGenerateColumns="False" Margin="10"
                              IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="PlayerList_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="80"/>
                            <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="80"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60"/>
                            <DataGridTextColumn Header="Zone" Binding="{Binding Zone}" Width="150"/>
                            <DataGridTextColumn Header="IP Address" Binding="{Binding IPAddress}" Width="120"/>
                            <DataGridTemplateColumn Header="Account" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Account" Click="BtnPlayerAccount_Click" Tag="{Binding Name}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Economy Tab -->
            <TabItem Header="Economy">
                <TabControl>
                    <!-- Auction House Sub-tab -->
                    <TabItem Header="Auction House">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Controls -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="AuctionSearch" Width="200" Height="30" Margin="5"/>
                                <Button Content="Search" Width="80" Height="30" Margin="5" Click="BtnSearchAuctions_Click"/>
                                <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshAuctions_Click"/>
                            </StackPanel>
                            
                            <!-- Auction DataGrid -->
                            <DataGrid x:Name="DgAuctions" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="200"/>
                                    <DataGridTextColumn Header="Seller" Binding="{Binding Seller}" Width="120"/>
                                    <DataGridTextColumn Header="Buyout" Binding="{Binding Buyout}" Width="100"/>
                                    <DataGridTextColumn Header="Bid" Binding="{Binding Bid}" Width="100"/>
                                    <DataGridTextColumn Header="Time Left" Binding="{Binding TimeLeft}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Mail Sub-tab -->
                    <TabItem Header="Mail">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Send Mail Section -->
                            <Border Grid.Row="0" BorderBrush="#FF555555" BorderThickness="1" Background="#FF222222" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Send Mail" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Recipient:" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                        <TextBox x:Name="MailRecipient" Grid.Column="1" Height="25" Margin="0,0,10,0"/>
                                        <CheckBox x:Name="MailSendToAll" Grid.Column="2" Content="Send to All" VerticalAlignment="Center" Foreground="LightGray"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Subject:" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                        <TextBox x:Name="MailSubject" Grid.Column="1" Height="25"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Body:" VerticalAlignment="Top" Foreground="LightGray" Margin="0,0,5,0"/>
                                        <TextBox x:Name="MailBody" Grid.Column="1" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Gold (copper):" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                        <TextBox x:Name="MailGold" Grid.Column="1" Height="25" Text="0"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Send Mail" Width="100" Height="30" Margin="5" Click="BtnSendMail_Click"/>
                                        <Button Content="Clear" Width="80" Height="30" Margin="5" Click="BtnClearMail_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- View Mail Section -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="MailSearch" Width="200" Height="30" Margin="5"/>
                                <Button Content="Search" Width="80" Height="30" Margin="5" Click="BtnSearchMail_Click"/>
                                <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshMail_Click"/>
                            </StackPanel>
                            
                            <!-- Mail DataGrid -->
                            <DataGrid x:Name="DgMail" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Sender" Binding="{Binding Sender}" Width="120"/>
                                    <DataGridTextColumn Header="Receiver" Binding="{Binding Receiver}" Width="120"/>
                                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="200"/>
                                    <DataGridTextColumn Header="Has Items" Binding="{Binding HasItems}" Width="80"/>
                                    <DataGridTextColumn Header="Gold" Binding="{Binding Gold}" Width="80"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Currency/Points Sub-tab -->
                    <TabItem Header="Currency">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Controls -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="CurrencySearch" Width="200" Height="30" Margin="5"/>
                                <Button Content="Search" Width="80" Height="30" Margin="5" Click="BtnSearchCurrency_Click"/>
                                <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshCurrency_Click"/>
                            </StackPanel>
                            
                            <!-- Currency DataGrid -->
                            <DataGrid x:Name="DgCurrency" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Character" Binding="{Binding Character}" Width="150"/>
                                    <DataGridTextColumn Header="Honor Points" Binding="{Binding HonorPoints}" Width="100"/>
                                    <DataGridTextColumn Header="Arena Points" Binding="{Binding ArenaPoints}" Width="100"/>
                                    <DataGridTextColumn Header="Gold" Binding="{Binding Gold}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Mail Templates Sub-tab -->
                    <TabItem Header="Mail Templates">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Controls -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="New Template" Width="120" Height="30" Margin="5" Click="BtnNewMailTemplate_Click"/>
                                <Button Content="Refresh" Width="80" Height="30" Margin="5" Click="BtnRefreshMailTemplates_Click"/>
                            </StackPanel>
                            
                            <!-- Templates DataGrid -->
                            <DataGrid x:Name="DgMailTemplates" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="200"/>
                                    <DataGridTextColumn Header="Money A" Binding="{Binding MoneyA}" Width="80"/>
                                    <DataGridTextColumn Header="Money H" Binding="{Binding MoneyH}" Width="80"/>
                                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="60"/>
                                    <DataGridTemplateColumn Header="Actions" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Send" Click="BtnSendTemplate_Click" Tag="{Binding Id}" Width="50" Margin="0,0,5,0"/>
                                                    <Button Content="Edit" Click="BtnEditTemplate_Click" Tag="{Binding Id}" Width="50"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
            
            <!-- Server Analytics Tab -->
            <TabItem Header="Server Analytics">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Server Analytics Dashboard" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Current Stats -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#FF2A2A2A" Padding="15" Margin="0,0,5,0" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="Online Players" FontSize="12" Foreground="#FF888888" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtOnlinePlayers" Text="0" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Background="#FF2A2A2A" Padding="15" Margin="0,0,5,0" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="CPU Usage" FontSize="12" Foreground="#FF888888" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtCpuUsage" Text="0%" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Background="#FF2A2A2A" Padding="15" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="Memory Usage" FontSize="12" Foreground="#FF888888" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtMemoryUsage" Text="0 MB" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- Player Count Over Time -->
                        <TextBlock Text="Player Count Over Time" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid x:Name="DgPlayerCountHistory" Height="150" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="Player Count" Binding="{Binding PlayerCount}" Width="100"/>
                                <DataGridTextColumn Header="Peak This Hour" Binding="{Binding PeakThisHour}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- Peak Hours -->
                        <TextBlock Text="Peak Hours (Last 24 Hours)" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid x:Name="DgPeakHours" Height="150" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Hour" Binding="{Binding Hour}" Width="100"/>
                                <DataGridTextColumn Header="Average Players" Binding="{Binding AveragePlayers}" Width="120"/>
                                <DataGridTextColumn Header="Peak Players" Binding="{Binding PeakPlayers}" Width="100"/>
                                <DataGridTextColumn Header="Peak Time" Binding="{Binding PeakTime}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- Performance Metrics -->
                        <TextBlock Text="Performance Metrics" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="CPU History" Foreground="White" Margin="0,0,0,5"/>
                                <DataGrid x:Name="DgCpuHistory" Height="150" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="120"/>
                                        <DataGridTextColumn Header="CPU %" Binding="{Binding CpuUsage}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Memory History" Foreground="White" Margin="0,0,0,5"/>
                                <DataGrid x:Name="DgMemoryHistory" Height="150" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="120"/>
                                        <DataGridTextColumn Header="Memory MB" Binding="{Binding MemoryUsage}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="Refresh Analytics" Width="150" Height="30" Margin="0,20,0,0" HorizontalAlignment="Left" Click="BtnRefreshAnalytics_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Communication Tab -->
            <TabItem Header="Communication">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Communication Center" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- In-Game Announcement Templates -->
                        <TextBlock Text="In-Game Announcement Templates" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtAnnouncementMessage" Grid.Column="0" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,5,0" Text="Enter announcement message..."/>
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <Button Content="Send Announcement" Width="150" Height="30" Margin="0,0,0,5" Click="BtnSendAnnouncement_Click"/>
                                <ComboBox x:Name="CmbAnnouncementType" Width="150" Height="30">
                                    <ComboBoxItem Content="Global (all)" Tag="announce"/>
                                    <ComboBoxItem Content="GM (staff only)" Tag="gmannounce"/>
                                    <ComboBoxItem Content="Notification" Tag="notify"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Quick Templates -->
                        <TextBlock Text="Quick Templates" FontSize="12" Foreground="#FF888888" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Button Content="Server Restarting" Width="120" Height="25" Margin="0,0,5,0" Click="BtnTemplateRestart_Click"/>
                            <Button Content="Maintenance Mode" Width="120" Height="25" Margin="0,0,5,0" Click="BtnTemplateMaintenance_Click"/>
                            <Button Content="Welcome" Width="120" Height="25" Click="BtnTemplateWelcome_Click"/>
                        </StackPanel>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- Broadcast Message History -->
                        <TextBlock Text="Broadcast Message History" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid x:Name="DgBroadcastHistory" Height="200" Margin="0,5" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=HH:mm:ss}" Width="80"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Clear History" Width="100" Height="30" Margin="0,5,0,0" HorizontalAlignment="Left" Click="BtnClearBroadcastHistory_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Server Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Server Directory -->
                        <TextBlock Text="Server Directory:" Margin="0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtServerDirectory" Grid.Column="0" Height="30" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse" Width="80" Height="30" Click="BtnBrowseServerDir_Click"/>
                        </Grid>
                        
                        <!-- Config Directory -->
                        <TextBlock Text="Config Directory:" Margin="0,15,0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtConfigDirectory" Grid.Column="0" Height="30" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse" Width="80" Height="30" Click="BtnBrowseConfigDir_Click"/>
                        </Grid>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <TextBlock Text="MySQL Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- MySQL Host -->
                        <TextBlock Text="MySQL Host:" Margin="0,5"/>
                        <TextBox x:Name="TxtMySqlHost" Height="30" Margin="0,5"/>
                        
                        <!-- MySQL Port -->
                        <TextBlock Text="MySQL Port:" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtMySqlPort" Height="30" Margin="0,5"/>
                        
                        <!-- Character Database -->
                        <TextBlock Text="Character Database:" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtCharacterDatabase" Height="30" Margin="0,5"/>
                        
                        <!-- Auth Database -->
                        <TextBlock Text="Auth Database:" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtAuthDatabase" Height="30" Margin="0,5"/>
                        
                        <!-- MySQL User -->
                        <TextBlock Text="MySQL User:" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtMySqlUser" Height="30" Margin="0,5"/>
                        
                        <!-- MySQL Password -->
                        <TextBlock Text="MySQL Password:" Margin="0,10,0,5"/>
                        <PasswordBox x:Name="TxtMySqlPassword" Height="30" Margin="0,5"/>
                        
                        <!-- Console Line Limit -->
                        <TextBlock Text="Console Line Limit:" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtConsoleLineLimit" Height="30" Margin="0,5" Text="100"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <TextBlock Text="Server Stability" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Auto-Restart on Crash -->
                        <CheckBox x:Name="ChkAutoRestartOnCrash" Content="Auto-Restart on Crash" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Automatically restart servers if they crash unexpectedly" FontSize="11" Foreground="#AAAAAA" Margin="20,0,0,10"/>
                        
                        <!-- Max Auto Restarts -->
                        <TextBlock Text="Max Auto Restarts:" Margin="0,5"/>
                        <TextBox x:Name="TxtMaxAutoRestarts" Height="30" Margin="0,5" Text="3"/>
                        <TextBlock Text="Maximum number of automatic restart attempts before giving up" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- Auto Restart Delay -->
                        <TextBlock Text="Auto Restart Delay (seconds):" Margin="0,5"/>
                        <TextBox x:Name="TxtAutoRestartDelay" Height="30" Margin="0,5" Text="5"/>
                        <TextBlock Text="Delay in seconds before attempting auto-restart" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- Crash Log Analysis -->
                        <CheckBox x:Name="ChkEnableCrashLogAnalysis" Content="Enable Crash Log Analysis" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Automatically analyze crash logs when servers crash" FontSize="11" Foreground="#AAAAAA" Margin="20,0,0,10"/>
                        <CheckBox x:Name="ChkKillExistingServers" Content="Kill Existing Servers on Startup" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Automatically kill any running authserver/worldserver processes on startup" FontSize="11" Foreground="#AAAAAA" Margin="20,0,0,10"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <TextBlock Text="Health Monitoring" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Enable Health Monitoring -->
                        <CheckBox x:Name="ChkEnableHealthMonitoring" Content="Enable Health Monitoring" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Monitor server health and send alerts for issues" FontSize="11" Foreground="#AAAAAA" Margin="20,0,0,10"/>
                        
                        <!-- Memory Alert Threshold -->
                        <TextBlock Text="Memory Alert Threshold (MB):" Margin="0,5"/>
                        <TextBox x:Name="TxtMemoryAlertThreshold" Height="30" Margin="0,5" Text="4096"/>
                        <TextBlock Text="Alert when memory usage exceeds this threshold" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- Health Check Interval -->
                        <TextBlock Text="Health Check Interval (seconds):" Margin="0,5"/>
                        <TextBox x:Name="TxtHealthCheckInterval" Height="30" Margin="0,5" Text="5"/>
                        <TextBlock Text="How often to check server health" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <TextBlock Text="Database Backup" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Backup Before Restart -->
                        <CheckBox x:Name="ChkBackupBeforeRestart" Content="Backup database before server restart" Margin="0,5"/>
                        <TextBlock Text="Automatically backup characters database before any restart" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- Backup Directory -->
                        <TextBlock Text="Backup Directory:" Margin="0,5"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBackupDirectory" Grid.Column="0" Height="30" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse" Width="80" Height="30" Click="BtnBrowseBackupDir_Click"/>
                        </Grid>
                        <TextBlock Text="Where to store database backup files" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- MySQL Dump Path -->
                        <TextBlock Text="MySQL Dump Path:" Margin="0,5"/>
                        <TextBox x:Name="TxtMySqlDumpPath" Height="30" Margin="0,5" Text="mysqldump"/>
                        <TextBlock Text="Full path to mysqldump.exe (e.g., C:\Program Files\MySQL\bin\mysqldump.exe)" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- MySQL Path -->
                        <TextBlock Text="MySQL Path:" Margin="0,5"/>
                        <TextBox x:Name="TxtMySqlPath" Height="30" Margin="0,5" Text="mysql"/>
                        <TextBlock Text="Full path to mysql.exe (e.g., C:\Program Files\MySQL\bin\mysql.exe)" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        
                        <!-- Manual Backup/Restore -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5">
                            <Button Content="Backup Now" Width="120" Height="35" Margin="5" Click="BtnBackupNow_Click"/>
                            <Button Content="Restore Backup" Width="120" Height="35" Margin="5" Click="BtnRestoreBackup_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtBackupStatus" Text="" FontSize="11" Foreground="#AAAAAA" Margin="0,5,0,10"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <TextBlock Text="Item Cache" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Refresh item data from acore_world database" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        <Button Content="Refresh Item Cache" Width="150" Height="35" Margin="0,5" Click="BtnRefreshItemCache_Click"/>
                        <TextBlock x:Name="TxtItemCacheStatus" Text="" FontSize="11" Foreground="#AAAAAA" Margin="0,5,0,10"/>
                        
                        <Separator Margin="0,20,0,20"/>
                        
                        <!-- Save/Load Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
                            <Button Content="Load Settings" Width="120" Height="35" Margin="5" Click="BtnLoadSettings_Click"/>
                            <Button Content="Save Settings" Width="120" Height="35" Margin="5" Click="BtnSaveSettings_Click"/>
                            <Button Content="Apply and Restart" Width="140" Height="35" Margin="5" Click="BtnApplySettings_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- Config Tab -->
            <TabItem Header="Config">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Config File Selection -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                        <ComboBox x:Name="CmbConfigFile" Width="200" Height="30" Margin="5">
                            <ComboBoxItem Content="worldserver.conf"/>
                            <ComboBoxItem Content="authserver.conf"/>
                        </ComboBox>
                        <Button Content="Load" Width="80" Height="30" Margin="5" Click="BtnLoadConfig_Click"/>
                        <Button Content="Save" Width="80" Height="30" Margin="5" Click="BtnSaveConfig_Click"/>
                        <Button Content="Apply" Width="80" Height="30" Margin="5" Click="BtnApplyConfig_Click"/>
                    </StackPanel>
                    
                    <!-- Config Editor -->
                    <RichTextBox x:Name="ConfigEditor" Grid.Row="1" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" Margin="10"/>
                    
                    <!-- Config Search -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
                        <TextBox x:Name="ConfigSearch" Width="300" Height="30" Margin="5"/>
                        <Button Content="Find" Width="80" Height="30" Margin="5" Click="BtnFindConfig_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
