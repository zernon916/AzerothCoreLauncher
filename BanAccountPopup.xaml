<Window x:Class="AzerothCoreLauncher.BanAccountPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ban Account" Height="300" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Background="#FF1E1E1E" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Account Name -->
        <StackPanel Grid.Row="0" Margin="0,10">
            <TextBlock Text="Account Name:" Foreground="White" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtAccountName" Text="" Foreground="LightGreen" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
        
        <!-- Player Name -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Player Name:" Foreground="White" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtPlayerName" Text="" Foreground="LightBlue" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
        
        <!-- Duration -->
        <StackPanel Grid.Row="2" Margin="0,10">
            <TextBlock Text="Duration:" Foreground="White" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboDuration" Height="30">
                <ComboBoxItem Content="1d" Tag="1d"/>
                <ComboBoxItem Content="3d" Tag="3d"/>
                <ComboBoxItem Content="1w" Tag="1w"/>
                <ComboBoxItem Content="perm" Tag="perm" IsSelected="True"/>
            </ComboBox>
        </StackPanel>
        
        <!-- Reason -->
        <StackPanel Grid.Row="3" Margin="0,10">
            <TextBlock Text="Reason:" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtReason" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>
        
        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="BtnBan" Content="Ban" Width="100" Height="30" Margin="5"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
