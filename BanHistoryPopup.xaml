<Window x:Class="AzerothCoreLauncher.BanHistoryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ban History" Height="600" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Background="#FF1E1E1E" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,10">
            <TextBlock x:Name="TxtTitle" Text="Ban History" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock x:Name="TxtTarget" Text="" FontSize="14" Foreground="LightGreen" Margin="0,5"/>
        </StackPanel>
        
        <!-- Ban History DataGrid -->
        <DataGrid x:Name="DgBanHistory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ban Date" Binding="{Binding BanDateFormatted}" Width="150"/>
                <DataGridTextColumn Header="Unban Date" Binding="{Binding UnbanDateFormatted}" Width="150"/>
                <DataGridTextColumn Header="Banned By" Binding="{Binding BannedBy}" Width="120"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding BanReason}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding ActiveFormatted}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Close Button -->
        <Button Grid.Row="2" Content="Close" Width="100" Height="30" HorizontalAlignment="Center" Margin="0,10" Click="BtnClose_Click"/>
    </Grid>
</Window>
