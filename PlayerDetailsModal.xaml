<Window x:Class="AzerothCoreLauncher.PlayerDetailsModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Player Details" Height="700" Width="900"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        Background="#FF2D2D30">
    <Grid>
        <TabControl>
            <!-- Profile Tab -->
            <TabItem Header="Profile">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Character Information" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <StackPanel>
                            <TextBlock x:Name="TxtProfileName" Text="Name: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileLevel" Text="Level: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileRace" Text="Race: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileClass" Text="Class: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileZone" Text="Zone: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileMap" Text="Map: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileOnline" Text="Online: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfilePlaytime" Text="Total Playtime: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <TextBlock x:Name="TxtProfileLevelTime" Text="Level Playtime: " Foreground="LightGray" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Gold:" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                <TextBox x:Name="TxtProfileGold" Width="80" Height="25" Margin="0,0,10,0" Foreground="Black"/>
                                <TextBlock Text="Silver:" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                <TextBox x:Name="TxtProfileSilver" Width="80" Height="25" Margin="0,0,10,0" Foreground="Black"/>
                                <TextBlock Text="Copper:" VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,5,0"/>
                                <TextBox x:Name="TxtProfileCopper" Width="80" Height="25" Margin="0,0,10,0" Foreground="Black"/>
                                <Button x:Name="BtnSaveGold" Content="Save" Width="80" Height="25" Click="BtnSaveGold_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Inventory Tab -->
            <TabItem Header="Inventory">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filter Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnFilterEquipment" Content="Equipment" Width="100" Height="30" Margin="5" Click="BtnFilterEquipment_Click"/>
                        <Button x:Name="BtnFilterBackpack" Content="Backpack" Width="100" Height="30" Margin="5" Click="BtnFilterBackpack_Click"/>
                        <Button x:Name="BtnFilterBank" Content="Bank" Width="100" Height="30" Margin="5" Click="BtnFilterBank_Click"/>
                        <Button x:Name="BtnFilterAll" Content="All" Width="100" Height="30" Margin="5" Click="BtnFilterAll_Click"/>
                    </StackPanel>
                    
                    <!-- Inventory DataGrid -->
                    <DataGrid x:Name="DgInventory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Slot" Binding="{Binding Slot}" Width="50"/>
                            <DataGridTextColumn Header="Item Entry" Binding="{Binding ItemEntry}" Width="80"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="200"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                            <DataGridTextColumn Header="Durability" Binding="{Binding Durability}" Width="80"/>
                            <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Skills Tab -->
            <TabItem Header="Skills">
                <Grid Margin="10">
                    <DataGrid x:Name="DgSkills" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Skill ID" Binding="{Binding SkillId}" Width="80"/>
                            <DataGridTextColumn Header="Skill Name" Binding="{Binding SkillName}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="80"/>
                            <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Quests Tab -->
            <TabItem Header="Quests">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filter Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnFilterActiveQuests" Content="Active" Width="100" Height="30" Margin="5" Click="BtnFilterActiveQuests_Click"/>
                        <Button x:Name="BtnFilterCompletedQuests" Content="Completed" Width="100" Height="30" Margin="5" Click="BtnFilterCompletedQuests_Click"/>
                        <Button x:Name="BtnFilterAllQuests" Content="All" Width="100" Height="30" Margin="5" Click="BtnFilterAllQuests_Click"/>
                    </StackPanel>
                    
                    <!-- Quests DataGrid -->
                    <DataGrid x:Name="DgQuests" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Quest ID" Binding="{Binding QuestId}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60"/>
                            <DataGridTextColumn Header="Explored" Binding="{Binding Explored}" Width="60"/>
                            <DataGridTextColumn Header="MobCount1" Binding="{Binding MobCount1}" Width="80"/>
                            <DataGridTextColumn Header="MobCount2" Binding="{Binding MobCount2}" Width="80"/>
                            <DataGridTextColumn Header="MobCount3" Binding="{Binding MobCount3}" Width="80"/>
                            <DataGridTextColumn Header="MobCount4" Binding="{Binding MobCount4}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount1" Binding="{Binding ItemCount1}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount2" Binding="{Binding ItemCount2}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount3" Binding="{Binding ItemCount3}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount4" Binding="{Binding ItemCount4}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount5" Binding="{Binding ItemCount5}" Width="80"/>
                            <DataGridTextColumn Header="ItemCount6" Binding="{Binding ItemCount6}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
